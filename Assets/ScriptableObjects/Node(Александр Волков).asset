  m_Script: {fileID: 11500000, guid: 72804f335d68d0040939e3c82097d8a0, type: 3}
  m_Name: "Node(\u0410\u043B\u0435\u043A\u0441\u0430\u043D\u0434\u0440 \u0412\u043E\u043B\u043A\u043E\u0432)"
  m_EditorClassIdentifier: Assembly-CSharp::DialogesSO
  CharacterSprite: {fileID: 0}
  Nodes:
  - DialogueText: "\u0417\u0430\u0447\u0435\u043C \u044F \u0442\u0443\u0442 ? "
    FirstButtonText: "\u0413\u0434\u0435 \u0431\u044B\u043B\u0438 \u0432 \u0441\u0440\u0435\u0434\u0443
      \u0432\u0435\u0447\u0435\u0440\u043E\u043C ? "
    SecondButtonText: "\u0415\u0441\u0442\u044C \u043E\u0441\u043D\u043E\u0432\u0430\u043D\u0438\u044F
      \u0441\u0447\u0438\u0442\u0430\u0442\u044C \u0432\u0430\u0441 \u0432\u0438\u043D\u043E\u0432\u043D\u044B\u043C   "
    FirstNextNode: 1
    SecondNextNode: 2
  - DialogueText: "\u0414\u043E\u043C\u0430, \u0442\u0435\u043B\u0435\u043A \u0441\u043C\u043E\u0442\u0440\u0435\u043B.\u041F\u043E\u0442\u043E\u043C
      \u0432\u044B\u0445\u043E\u0434\u0438\u043B \u0437\u0430 \u0441\u0438\u0433\u0430\u0440\u0435\u0442\u0430\u043C\u0438 "
    FirstButtonText: "\u0417\u043D\u0430\u043B\u0438 \u0436\u0435\u0440\u0442\u0432\u0443?"
    SecondButtonText: "\u0427\u0442\u043E \u0432\u0438\u0434\u0435\u043B\u0438 \u0432\u043E\u0437\u043B\u0435
      \u0434\u043E\u043C\u0430?"
    FirstNextNode: 3
    SecondNextNode: 4
  - DialogueText: "\u042F \u0432 \u0437\u0430\u0432\u044F\u0437\u043A\u0435, \u0438
      \u0442\u0430\u043A\u0438\u043C \u043D\u0435 \u0437\u0430\u043D\u0438\u043C\u0430\u044E\u0441\u044C "
    FirstButtonText: "\u0417\u043D\u0430\u043B\u0438 \u0436\u0435\u0440\u0442\u0432\u0443?"
    SecondButtonText: "\u0427\u0442\u043E \u0432\u0438\u0434\u0435\u043B\u0438 \u0432\u043E\u0437\u043B\u0435
      \u0434\u043E\u043C\u0430?"
    FirstNextNode: 3
    SecondNextNode: 4
  - DialogueText: "\u0417\u043D\u0430\u043B \u0435\u0433\u043E ... \u0425\u043E\u0440\u043E\u0448\u043E
      \u0437\u043D\u0430\u043B, \u0434\u0435\u043D\u0435\u0433 \u0435\u043C\u0443
      \u0434\u043E\u043B\u0436\u0435\u043D \u0431\u044B\u043B "
    FirstButtonText: "\u0423 \u0432\u0430\u0441 \u0431\u044B\u043B\u0438 \u0440\u0430\u0437\u043D\u043E\u0433\u043B\u0430\u0441\u0438\u044F 
      ? "
    SecondButtonText: "\u042F \u0437\u043D\u0430\u044E \u044D\u0442\u043E \u0442\u044B "
    FirstNextNode: 5
    SecondNextNode: 6
  - DialogueText: "\u042F \u043D\u0435 \u043A\u0430\u0440\u0430\u0443\u043B\u044E
      \u0435\u0433\u043E \u043F\u043E\u0434 \u043E\u043A\u043D\u0430\u043C\u0438.
      \u041E\u0442\u043A\u0443\u0434\u0430 \u043C\u043D\u0435 \u0437\u043D\u0430\u0442\u044C,
      \u0433\u0434\u0435 \u043E\u043D \u0431\u044B\u043B \u0432 \u0442\u043E\u0442
      \u0432\u0435\u0447\u0435\u0440? \u041C\u044B \u0438 \u0442\u0430\u043A \u0432\u0438\u0434\u0435\u043B\u0438\u0441\u044C
      \u0440\u0435\u0434\u043A\u043E."
    FirstButtonText: "\u0423 \u0432\u0430\u0441 \u0431\u044B\u043B\u0438 \u0440\u0430\u0437\u043D\u043E\u0433\u043B\u0430\u0441\u0438\u044F 
      ? "
    SecondButtonText: "\u042F \u0437\u043D\u0430\u044E \u044D\u0442\u043E \u0442\u044B "
    FirstNextNode: 5
    SecondNextNode: 6
  - DialogueText: "\u041D\u0435\u0442 "
    FirstButtonText: "\u041C\u043E\u0436\u0435\u0442\u0435 \u0438\u0434\u0442\u0438 "
    SecondButtonText: "\u0417\u0430\u0434\u0435\u0440\u0436\u0430\u0442\u044C "
    FirstNextNode: -1
    SecondNextNode: -1
  - DialogueText: "\u0410\u0433\u0430, \u0434\u0430\u0432\u0430\u0439 \u043C\u0435\u043D\u0442
      \u043F\u043E\u043F\u0440\u043E\u0431\u0443\u0439 "
    FirstButtonText: "\u041C\u043E\u0436\u0435\u0442\u0435 \u0438\u0434\u0442\u0438 "
    SecondButtonText: "\u0417\u0430\u0434\u0435\u0440\u0436\u0430\u0442\u044C "
    FirstNextNode: -1
    SecondNextNode: -1
