  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 72804f335d68d0040939e3c82097d8a0, type: 3}
  m_Name: "Node(\u0410\u0440\u0442\u0435\u043C \u041B\u0438\u0441\u0438\u0446\u044B\u043D)"
  m_EditorClassIdentifier: Assembly-CSharp::DialogesSO
  CharacterSprite: {fileID: 0}
  Nodes:
  - DialogueText: "\u0417\u0430\u0447\u0435\u043C \u043C\u0435\u043D\u044F \u0432\u043E\u043E\u0431\u0449\u0435
      \u0441\u044E\u0434\u0430 \u043F\u0440\u0438\u0442\u0430\u0449\u0438\u043B\u0438?"
    FirstButtonText: "\u0413\u0434\u0435 \u0432\u044B \u043D\u0430\u0445\u043E\u0434\u0438\u043B\u0438\u0441\u044C
      \u0432\u0447\u0435\u0440\u0430 \u0432\u0435\u0447\u0435\u0440\u043E\u043C?"
    SecondButtonText: "\u0412\u044B \u0437\u043D\u0430\u043B\u0438 \u043F\u043E\u0433\u0438\u0431\u0448\u0435\u0433\u043E?"
    FirstNextNode: 1
    SecondNextNode: 2
  - DialogueText: "\u0414\u043E\u043C\u0430. \u041F\u043E\u0442\u043E\u043C \u0432\u044B\u0448\u0435\u043B
      \u043A\u0443\u043F\u0438\u0442\u044C \u0441\u0438\u0433\u0430\u0440\u0435\u0442\u044B.
      \u041C\u0438\u043D\u0443\u0442 \u043D\u0430 \u0434\u0432\u0430\u0434\u0446\u0430\u0442\u044C."
    FirstButtonText: "\u0427\u0442\u043E \u0443 \u0432\u0430\u0441 \u0441 \u0440\u0443\u043A\u0430\u043C\u0438
      ? "
    SecondButtonText: "\u041F\u043E\u0447\u0435\u043C\u0443 \u0432\u0430\u0448\u0438
      \u043E\u0442\u043F\u0435\u0447\u0430\u0442\u043A\u0438 \u043D\u0430\u0448\u043B\u0438
      \u0432 \u043A\u0432\u0430\u0440\u0442\u0438\u0440\u0435?"
    FirstNextNode: 3
    SecondNextNode: 4
  - DialogueText: "\u0417\u043D\u0430\u043B, \u043E\u043D \u043C\u043D\u0435 \u0434\u043E\u043B\u0436\u0435\u043D
      \u0431\u044B\u043B"
    FirstButtonText: "\u0413\u0434\u0435 \u0432\u044B \u043D\u0430\u0445\u043E\u0434\u0438\u043B\u0438\u0441\u044C
      \u0432\u0447\u0435\u0440\u0430 \u0432\u0435\u0447\u0435\u0440\u043E\u043C?"
    SecondButtonText: "\u041F\u043E\u0447\u0435\u043C\u0443 \u0432\u0430\u0448\u0438
      \u043E\u0442\u043F\u0435\u0447\u0430\u0442\u043A\u0438 \u043D\u0430\u0448\u043B\u0438
      \u0432 \u043A\u0432\u0430\u0440\u0442\u0438\u0440\u0435?"
    FirstNextNode: 3
    SecondNextNode: 4
  - DialogueText: "\u0422\u0435\u0431\u044F \u044D\u0442\u043E \u0432\u043E\u043B\u043D\u043E\u0432\u0430\u0442\u044C
      \u043D\u0435 \u0434\u043E\u043B\u0436\u043D\u043E, \u0445\u043E\u0447\u0435\u0448\u044C
      \u0441\u043F\u0440\u043E\u0441\u0438 \u0434\u0440\u0443\u0433\u043E\u0433\u043E "
    FirstButtonText: "\u0413\u0434\u0435 \u0432\u044B \u043D\u0430\u0445\u043E\u0434\u0438\u043B\u0438\u0441\u044C
      \u0432\u0447\u0435\u0440\u0430 \u0432\u0435\u0447\u0435\u0440\u043E\u043C?"
    SecondButtonText: "\u041F\u043E\u0447\u0435\u043C\u0443 \u0432\u0430\u0448\u0438
      \u043E\u0442\u043F\u0435\u0447\u0430\u0442\u043A\u0438 \u043D\u0430\u0448\u043B\u0438
      \u0432 \u043A\u0432\u0430\u0440\u0442\u0438\u0440\u0435?"
    FirstNextNode: 5
    SecondNextNode: 6
  - DialogueText: "\u042F \u043D\u0435 \u0431\u044B\u043B \u0443 \u043D\u0435\u0433\u043E
      \u0434\u043E\u043C\u0430"
    FirstButtonText: "\u0421 \u0442\u043E\u0431\u043E\u0439 \u0432\u0441\u0435 \u0445\u043E\u0440\u043E\u0448\u043E
      ? "
    SecondButtonText: "\u041F\u043E\u0447\u0435\u043C\u0443 \u0432\u0430\u0448\u0438
      \u043E\u0442\u043F\u0435\u0447\u0430\u0442\u043A\u0438 \u043D\u0430\u0448\u043B\u0438
      \u0432 \u043A\u0432\u0430\u0440\u0442\u0438\u0440\u0435?"
    FirstNextNode: 5
    SecondNextNode: 6
  - DialogueText: "\u0410 \u0443 \u0442\u0435\u0431\u044F \u0443 \u0441\u0430\u043C\u043E\u0433\u043E
      \u0432\u0441\u0435 \u0434\u043E\u043C\u0430 ? "
    FirstButtonText: "\u0427\u0442\u043E ? "
    SecondButtonText: "\u0417\u0430\u0434\u0435\u0440\u0436\u0430\u0442\u044C "
    FirstNextNode: -1
    SecondNextNode: -1
  - DialogueText: "\u0418\u0434\u0438 \u043B\u0435\u0441\u043E\u043C "
    FirstButtonText: "\u041C\u043E\u0436\u0435\u0442\u0435 \u0438\u0434\u0442\u0438 "
    SecondButtonText: "\u0417\u0430\u0434\u0435\u0440\u0436\u0430\u0442\u044C "
    FirstNextNode: -1
    SecondNextNode: -1
