  m_Name: "Node(\u041C\u0438\u0445\u0430\u0438\u043B \u041E\u0440\u043B\u043E\u0432.\u0441\u043B\u0435\u0434)"
  m_EditorClassIdentifier: Assembly-CSharp::DialogesSO
  CharacterSprite: {fileID: 0}
  Nodes:
  - DialogueText: " \u0428\u0432\u0430\u0440\u0446\u043C\u0430\u043D \u043F\u043E\u0437\u0434\u0440\u0430\u0432\u043B\u044F\u044E! 
      \u041F\u0435\u0440\u0432\u043E\u0435 \u0441\u0430\u043C\u043E\u0441\u0442\u043E\u044F\u0442\u0435\u043B\u044C\u043D\u043E\u0435
      \u0434\u0435\u043B\u043E.  \u041D\u0435 \u0434\u0443\u043C\u0430\u043B, \u0447\u0442\u043E
      \u043E\u043D\u043E \u0434\u043E\u0441\u0442\u0430\u043D\u0435\u0442\u0441\u044F
      \u0438\u043C\u0435\u043D\u043D\u043E \u0442\u0435\u0431\u0435. \u041D\u043E
      \u0432\u044B\u0431\u043E\u0440\u0430 \u043D\u0435\u0442.  "
    FirstButtonText: "\u0414\u0430\u043B\u0435\u0435"
    SecondButtonText: "\u0414\u0430\u043B\u0435\u0435"
    FirstNextNode: 1
    SecondNextNode: 1
  - DialogueText: " \u0421\u0435\u0433\u043E\u0434\u043D\u044F \u043D\u043E\u0447\u044C\u044E
      \u043D\u0430\u0439\u0434\u0435\u043D \u0443\u0431\u0438\u0442\u044B\u043C \u0433\u0440\u0430\u0436\u0434\u0430\u043D\u0438\u043D
      \u0412\u0438\u043A\u0442\u043E\u0440 \u0421\u0430\u043C\u043E\u0439\u043B\u043E\u0432.\u0421\u043E\u0440\u043E\u043A
      \u0434\u0432\u0430 \u0433\u043E\u0434\u0430.\u041F\u0440\u0435\u0434\u043F\u0440\u0438\u043D\u0438\u043C\u0430\u0442\u0435\u043B\u044C. 
      \u0423\u0431\u0438\u0442 \u0443 \u0441\u0435\u0431\u044F \u0434\u043E\u043C\u0430.
      \u0421\u043E\u0441\u0435\u0434\u0438 \u043D\u0438\u0447\u0435\u0433\u043E \u043D\u0435
      \u0441\u043B\u044B\u0448\u0430\u043B\u0438. \u041E\u0440\u0443\u0434\u0438\u0435
      \u0443\u0431\u0438\u0439\u0441\u0442\u0432\u0430 \u0438\u0441\u0447\u0435\u0437\u043B\u043E.
      \u0427\u0435\u0442\u0432\u0435\u0440\u043E \u043F\u043E\u0434\u043E\u0437\u0440\u0435\u0432\u0430\u0435\u043C\u044B\u0445. "
    FirstButtonText: "\u0414\u0430\u043B\u0435\u0435"
    SecondButtonText: "\u0414\u0430\u043B\u0435\u0435"
    FirstNextNode: 2
    SecondNextNode: 2
  - DialogueText: "\u041F\u0440\u043E\u043A\u0443\u0440\u0430\u0442\u0443\u0440\u0430
      \u0442\u0440\u0435\u0431\u0443\u0435\u0442 \u0441\u0435\u0433\u043E\u0434\u043D\u044F
      \u0432\u044B\u0434\u0430\u0442\u044C \u043F\u043E\u0434\u043E\u0437\u0440\u0435\u0432\u0430\u0435\u043C\u043E\u0433\u043E
      \u0434\u043B\u044F \u0434\u0435\u043B\u0430. \u0412\u044B\u044F\u0441\u043D\u0438
      \u043A\u0442\u043E \u044D\u0442\u043E \u0441\u0434\u0435\u043B\u0430\u043B
      \u0438 \u0434\u043E\u043B\u043E\u0436\u0438 \u043E\u0431 \u044D\u0442\u043E\u043C
      \u043C\u043D\u0435 "
    FirstButtonText: "\u0415\u0441\u0442\u044C "
    SecondButtonText: "\u041C\u043E\u0436\u043D\u043E \u0432\u043E\u043F\u0440\u043E\u0441
      ? "
